#!/bin/bash

echo "=========================================="
echo " Provisioning Web Server (Apache + PHP)..."
echo "=========================================="

# Update package list
apt-get update -y

# Install Apache and PHP packages required for WordPress
apt-get install -y apache2 php libapache2-mod-php php-mysql

# Ensure Apache starts on boot and is running now
systemctl enable apache2
systemctl start apache2

# Create a test webpage so we know it worked!
echo "<h1>Welcome to Dibyashwor's Web Server!</h1><p>Apache and PHP are installed.</p>" > /var/www/html/index.html

echo "Web Server Provisioning Complete!"
